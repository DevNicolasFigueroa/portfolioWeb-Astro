---
import Header from "../components/Header.astro";
import "../styles/global.css";
import '@fontsource-variable/onest/wght.css';
---

<!doctype html>
<html lang="es">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<link rel="icon" href="/favicon.ico" />
		<meta name="generator" content={Astro.generator} />
		<title>Nicolás Figueroa - Portfolio</title>
	</head>
	<body>
		<div class="fixed inset-0 -z-10 w-full h-screen [background:radial-gradient(125%_125%_at_50%_10%,#000_40%,#63e_100%)]"></div>
		<Header />
		<slot />
		
	</body>
</html>

<style is:global>

	:root {
		color-scheme: light dark;
	}
	html {
		font-family: 'Onest variable',system-ui, sans-serif;
	}
	
	body {
		background-color: #0b0b0b;
		display: flex;
		flex-direction: column;
		min-height: 100vh;
	}

	@keyframes reveal {
		from {
			opacity: 0;
			transform: translateY(20px);
		}
		to {
			opacity: 1;
			transform: translateY(0);
		}
	}

	.animate-reveal {
		animation: reveal 0.8s ease-out forwards;
	}

	@keyframes shimmer {
		0% { background-position: -200% center; }
		100% { background-position: 200% center; }
	}

	.animate-shimmer {
		background: linear-gradient(90deg, #ffffff 0%, #a855f7 25%, #ffffff 50%, #a855f7 75%, #ffffff 100%);
		background-size: 200% auto;
		-webkit-background-clip: text;
		-webkit-text-fill-color: transparent;
		animation: shimmer 5s linear infinite;
	}
</style>
