---
    const PROJECTS = [
        {
            date: "February 2022",
            title: "Application UI code in Tailwind CSS",
            description: "Get access to over 20+ pages including a dashboard layout, charts, kanban board, calendar, and pre-order E-commerce & Marketing pages.",
            link: "#"
        },
        {
            date: "March 2022",
            title: "Marketing UI design in Figma",
            description: "Get access to over 20+ pages including a dashboard layout, charts, kanban board, calendar, and pre-order E-commerce & Marketing pages.",
            link: "#"
        },
        {
            date: "April 2022",
            title: "E-commerce UI code in Tailwind CSS",
            description: "Get access to over 20+ pages including a dashboard layout, charts, kanban board, calendar, and pre-order E-commerce & Marketing pages.",
            link: "#"
        }
    ]
---


<ol class="relative border-s border-default">                  
    {
        PROJECTS.map( project => (
             <li class="mb-10 ms-4">
                <div class="absolute w-3 h-3 bg-default rounded-full -left-1.5 border border-default"></div>
                <time class="mb-1 text-sm font-normal leading-none text-gray-400">{project.date}</time>
                <h3 class="text-lg font-semibold text-white">{project.title}</h3>
                <p class="mb-4 text-base font-normal text-gray-500">{project.description}</p>
                <a href={project.link} class="inline-flex items-center px-4 py-2 text-sm font-medium text-center text-white bg-blue-700 rounded-lg hover:bg-blue-800 focus:ring-4 focus:outline-none focus:ring-blue-300">
                    Saber Más
                    <svg aria-hidden="true" class="w-3 h-3 ml-2" fill="currentColor" viewBox="0 0 20 20" xmlns="http://www.w3.org/2000/svg"><path d="M11 5l1.41 1.41L8.83 10l3.58 3.59L11 15l-5-5z"></path></svg>
                </a>
             </li>
        ))
    }
</ol>

