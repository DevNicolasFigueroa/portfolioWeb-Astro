---
import Layout from '../layouts/Layout.astro';
import Badge from '../components/Badge.astro';
import LinkedIn from '../components/LinkedInIcon.astro';
import GithubIcon from '../components/GithubIcon.astro';
import GmailIcon from '../components/GmailIcon.astro';
import Projects from "../components/Projects.astro";
import AboutMe from "../components/AboutMe.astro";
import TechStack from "../components/TechStack.astro";
---

<Layout tittle="Portfolio de Nicolás Figueroa - Desarrollador FullStack Junior"
description>
    <main class="px-4">
        <section id="top" class="w-full max-w-4xl mx-auto flex flex-col justify-center min-h-[70vh] md:min-h-[85vh] py-20">
            <div class="animate-reveal">
                <h1 class="text-white text-4xl md:text-5xl font-bold flex flex-row gap-x-4 pb-10 items-center flex-wrap">
                    Hola, Soy <span class="animate-shimmer">Nicolás</span>
                    <a href="https://www.linkedin.com/in/nicol%C3%A1s-figueroa19203424n/" target="_blank" 
                    rel="noopener"
                    class="flex justify-center items-center transition hover:scale-105" 
                    >
                        <Badge>Disponible para trabajar</Badge>
                    </a>
                </h1>
                
                <h2 class="text-lg md:text-xl text-gray-300 leading-relaxed max-w-[700px] animate-reveal [animation-delay:200ms]">
                    <span class="text-yellow-200"> Desarrollador de software fullstack junior. </span> 

                    Apasionado por la tecnología y el aprendizaje continuo en el mundo del desarrollo de software.
                </h2>

                <div class="flex flex-wrap gap-4 mt-8 animate-reveal [animation-delay:400ms]">
                    <a href="https://www.linkedin.com/in/nicol%C3%A1s-figueroa19203424n/"
                        target="_blank"
                        rel="noopener" 
                        class="border border-white/10 rounded-lg flex items-center gap-x-2 py-2 px-4 text-sm bg-white/5 hover:bg-white/10 transition-colors">
                        <LinkedIn class="size-5" /> LinkedIn
                    </a>
                    <a href="https://github.com/DevNicolasFigueroa"
                        target="_blank"
                        rel="noopener"
                        class="border border-white/10 rounded-lg flex items-center gap-x-2 py-2 px-4 text-sm bg-white/5 hover:bg-white/10 transition-colors">
                        <GithubIcon class="size-5" /> Github
                    </a>
                    <a href="mailto:nicolas.figueroaa21@gmail.com"
                        target="_blank"
                        rel="noopener"
                        class="border border-white/10 rounded-lg flex items-center gap-x-2 py-2 px-4 text-sm bg-white/5 hover:bg-white/10 transition-colors">
                        <GmailIcon class="size-5" /> Gmail
                    </a>
                    <a href="/NicolasFigueroa.pdf"
                        download="CV_Nicolas_Figueroa.pdf"
                        class="border border-yellow-200/20 rounded-lg flex items-center gap-x-2 py-2 px-4 text-sm bg-yellow-200/5 text-yellow-200 hover:bg-yellow-200/10 transition-colors">
                        <svg class="size-5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
                            <path stroke-linecap="round" stroke-linejoin="round" d="M3 16.5v2.25A2.25 2.25 0 005.25 21h13.5A2.25 2.25 0 0021 18.75V16.5M16.5 12L12 16.5m0 0L7.5 12m4.5 4.5V3"></path>
                        </svg>
                        Currículum
                    </a>
                </div>
            </div>
        </section>

        <section id="sobre-mi" class="w-full max-w-4xl py-12 mx-auto">
            <h2 class="text-white text-3xl md:text-4xl font-bold mb-8 flex items-center gap-x-3">
                <svg class="w-8 h-8" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" d="M15.75 6a3.75 3.75 0 11-7.5 0 3.75 3.75 0 017.5 0zM4.501 20.118a7.5 7.5 0 0114.998 0A17.933 17.933 0 0112 21.75c-2.676 0-5.216-.584-7.499-1.632z"></path></svg>
                Sobre Mí
            </h2>
            <AboutMe />
        </section>

        <section id="stack" class="w-full max-w-4xl py-12 mx-auto mt-12">
            <h2 class="text-white text-3xl md:text-4xl font-bold mb-8 flex items-center gap-x-3">
                <svg class="w-8 h-8" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" d="M2.25 7.125C2.25 6.504 2.754 6 3.375 6h6c.621 0 1.125.504 1.125 1.125v3.75c0 .621-.504 1.125-1.125 1.125h-6a1.125 1.125 0 01-1.125-1.125v-3.75zM14.25 8.625c0-.621.504-1.125 1.125-1.125h5.25c.621 0 1.125.504 1.125 1.125v8.25c0 .621-.504 1.125-1.125 1.125h-5.25a1.125 1.125 0 01-1.125-1.125v-8.25zM3.75 16.125c0-.621.504-1.125 1.125-1.125h5.25c.621 0 1.125.504 1.125 1.125v2.25c0 .621-.504 1.125-1.125 1.125h-5.25a1.125 1.125 0 01-1.125-1.125v-2.25z"></path></svg>
                Stack Tecnológico
            </h2>
            <TechStack />
        </section>

        <section id="proyectos" class="w-full max-w-4xl py-12 mx-auto mt-12">
            <h2 class="text-white text-3xl md:text-4xl font-bold mb-8 flex items-center gap-x-3">
                <svg class="w-8 h-8" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" d="M17.25 6.75L22.5 12l-5.25 5.25m-10.5 0L1.5 12l5.25-5.25m7.5-3l-4.5 16.5"></path></svg>
                Proyectos
            </h2>
            <Projects />
        </section>
    </main>
</Layout>
