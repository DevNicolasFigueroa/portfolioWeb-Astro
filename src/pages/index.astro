---

import Layout from '../layouts/Layout.astro';
import Badge from '../components/Badge.astro';
import LinkedIn from '../components/LinkedInIcon.astro';
import GithubIcon from '../components/GithubIcon.astro';
import GmailIcon from '../components/GmailIcon.astro';
import Projects from "../components/Projects.astro";
---

<Layout tittle="Portfolio de Nicolás Figueroa - Desarrollador FullStack Junior"
description>
    <main class="px-4 py-12">
        <section class="w-full max-w-4xl py-12 mx-auto flex items-center justify-center min-h-screen">
            <div>
                <h1 class="text-white text-4xl md:text-5xl font-bold flex flex-row gap-x-4 pb-10 items-center flex-wrap">
                    Hola, Soy Nicolás 
                    <a href="https://www.linkedin.com/in/nicol%C3%A1s-figueroa19203424n/" target="_blank" 
                    rel="noopener"
                    class="flex justify-center items-center" 
                    >
                        <Badge>Disponible para trabajar</Badge>
                    </a>
                </h1>
                
                <h2 class="text-lg md:text-xl text-gray-300 leading-relaxed">
                    <span class="text-yellow-200"> Desarrollador de software fullstack junior. </span> 

                    Apasionado por la tecnología y el aprendizaje continuo en el mundo del desarrollo de software.
                </h2>

                    <div class="flex gap-x-7 mt-5">
                    <a href="https://www.linkedin.com/in/nicol%C3%A1s-figueroa19203424n/"
                        target="_blank"
                        rel="noopener" >
                        <LinkedIn /> LinkedIn
                    </a>
                    <a href="https://github.com/DevNicolasFigueroa"
                        target="_blank"
                        rel="noopener">
                        <GithubIcon /> Github
                    </a>
                    <a href="mailto:nicolas.figueroaa21@gmail.com"

                        target="_blank"
                        rel="noopener">
                        <GmailIcon /> Gmail
                    </a>
                </div>
            </div>
        </section>

        <section class="w-full max-w-4xl py-12 mx-auto">
            <h2 class="text-white text-3xl md:text-4xl font-bold mb-8">Proyectos</h2>
            <Projects />
        </section>
    </main>

</Layout>
